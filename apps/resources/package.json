{
  "name": "@namefi-astra/resources",
  "version": "0.1.17",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3002",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "data:ff": "git -C data fetch origin main --tags && git -C data checkout --detach origin/main",
    "data:install": "bun install --cwd data --frozen-lockfile",
    "predata:validate": "bun run data:install",
    "data:validate": "bun run --cwd data data:validate",
    "prelint:mdx": "bun run data:install",
    "lint:mdx": "bun run --cwd data lint:mdx",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@bprogress/next": "^3.2.12",
    "@c15t/nextjs": "^1.8.2",
    "@c15t/scripts": "^1.0.1",
    "@formatjs/intl-localematcher": "^0.5.4",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@namefi-astra/env": "workspace:*",
    "@next/mdx": "16.1.5",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.525.0",
    "motion": "^12.10.4",
    "negotiator": "^1.0.0",
    "next": "16.1.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^2.1.1",
    "remark-reading-time": "^2.0.2",
    "rss": "^1.2.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.0.2",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "@types/mdx": "^2.0.13",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^22.13.14",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/rss": "^0.0.32",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  }
}
