{
  "name": "@namefi-astra/resources",
  "version": "3.4.1",
  "private": true,
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "predev": "bun run sync-blog-assets",
    "dev": "next dev --port 3002",
    "prebuild": "bun run sync-blog-assets",
    "build": "next build",
    "sync-blog-assets": "mkdir -p public/blog-assets && cp -R data/content/assets/. public/blog-assets/",
    "typecheck": "tsgo --noEmit",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "data:ff": "git -C data fetch origin main --tags && git -C data checkout --detach origin/main",
    "data:install": "bun install --cwd data --frozen-lockfile",
    "predata:validate": "bun run data:install",
    "data:validate": "bun run --cwd data data:validate",
    "prelint:mdx": "bun run data:install",
    "lint:mdx": "bun run --cwd data lint:mdx",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@bprogress/next": "catalog:",
    "@c15t/nextjs": "catalog:",
    "@formatjs/intl-localematcher": "^0.5.4",
    "@mdx-js/loader": "catalog:",
    "@mdx-js/react": "catalog:",
    "@namefi-astra/common": "workspace:*",
    "@namefi-astra/env": "workspace:*",
    "@namefi-astra/ui": "workspace:*",
    "@next/mdx": "catalog:",
    "gray-matter": "^4.0.3",
    "lucide-react": "catalog:",
    "motion": "catalog:",
    "negotiator": "^1.0.0",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^2.1.1",
    "remark-reading-time": "^2.0.2",
    "rss": "^1.2.2",
    "server-only": "catalog:",
    "unist-util-visit": "^5.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@types/mdx": "catalog:",
    "@types/negotiator": "^0.6.4",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/rss": "^0.0.32",
    "@typescript/native-preview": "catalog:",
    "tailwindcss": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  }
}
