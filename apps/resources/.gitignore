# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

certificates

# Synced from data/content/assets by the sync-blog-assets script (pre-build/dev).
# Source of truth lives in the namefi-resources submodule.
/public/blog-assets/

# Generated by the Pagefind indexer (scripts/build-search-index.ts) at pre-build/
# dev time from the content submodule. Regenerated on every build.
/public/pagefind/
