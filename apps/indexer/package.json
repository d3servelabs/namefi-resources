{
  "name": "@namefi-astra/indexer",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "exports": {
    "./schema": "./ponder.schema.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "dev": "ponder dev",
    "start": "ponder start --log-format json --log-level debug --schema=\"__indexer_$(date +%Y-%m-%d_%H-%M-%S)\" --views-schema indexed_onchain_data",
    "start:with-schema": "./scripts/start-with-schema.sh",
    "serve": "ponder serve",
    "force-local": "ENVIRONMENT=local LOG_LEVEL=debug bun",
    "with-env": "infisical run --token=$INFISICAL_SERVICE_TOKEN -- bun",
    "generate-schema": "npx tsx src/generate-schema.ts",
    "migrate-schema": "npx tsx src/migrate-schema.ts",
    "migrate-schema:dry-run": "DRY_RUN=true npx tsx src/migrate-schema.ts",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@date-fns/tz": "^1.3.1",
    "@date-fns/utc": "^2.1.1",
    "@namefi-astra/env": "workspace:*",
    "@namefi-astra/utils": "workspace:*",
    "@namefi-astra/zod-dns": "workspace:*",
    "@ponder/utils": "^0.2.18",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "jose": "^6.0.12",
    "nodemailer": "^9.0.1",
    "pg": "^8.15.6",
    "ponder": "0.16.6",
    "ramda": "^0.30.1",
    "tsx": "^4.22.4",
    "undici": "^7.12.0",
    "viem": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.11.10",
    "@types/ramda": "^0.30.2",
    "drizzle-kit": "^0.31.5"
  },
  "engines": {
    "node": ">=18.14"
  }
}
