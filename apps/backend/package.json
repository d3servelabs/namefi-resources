{
  "name": "@namefi-astra/backend",
  "version": "0.3.155-beta",
  "type": "module",
  "exports": {
    "./trpc": "./src/trpc/index.ts",
    "./trpc/types": "./src/trpc/types.ts",
    "./openapi": "./src/routers/openapi.ts"
  },
  "imports": {
    "#lib/env": "./src/lib/env/index.ts",
    "#lib/login-notification": "./src/lib/login-notification/index.ts",
    "#lib/*": "./src/lib/*.ts",
    "#lib/ponder-client": "./src/lib/ponder-client/index.ts",
    "#services/*": "./src/services/*.ts",
    "#temporal/*": "./src/temporal/*.ts",
    "#temporal/shared/*": "./src/temporal/shared/*.ts",
    "#temporal/shared": "./src/temporal/shared/index.ts",
    "#trpc/*": "./src/trpc/*.ts",
    "#trpc": "./src/trpc/index.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist .react-email",
    "force-local": "ENVIRONMENT=local LOG_LEVEL=${LOG_LEVEL:-debug} bun",
    "dev": "ENVIRONMENT=local LOG_LEVEL=${LOG_LEVEL:-debug} bun run tsx watch src/index.ts",
    "dev:internal": "ENVIRONMENT=local LOG_LEVEL=${LOG_LEVEL:-debug} bun run tsx watch src/index.ts",
    "dev:temporal": "wait-on tcp:${TEMPORAL_SERVER_PORT:-7233} && ENVIRONMENT=local LOG_LEVEL=${LOG_LEVEL:-debug} bun run tsx watch src/temporal/main.temporal.ts",
    "dev:temporal:internal": "wait-on tcp:${TEMPORAL_SERVER_PORT:-7233} && ENVIRONMENT=local LOG_LEVEL=${LOG_LEVEL:-debug} bun run tsx watch src/temporal/main.temporal.ts",
    "with-env": "infisical run --silent --log-level error --token=$INFISICAL_SERVICE_TOKEN -- bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsgo --noEmit",
    "test": "bun --env-file .env.test test",
    "test:watch": "bun --env-file .env.test vitest",
    "test:coverage": "bun --env-file .env.test test --coverage --coverage-reporter=lcov",
    "test:ci": "cd ../.. && act -j test --input package_filter=\"@namefi-astra/backend\" --container-architecture linux/amd64",
    "build": "tsdown",
    "build:prod": "NODE_ENV=production tsdown",
    "bundle:workflows": "bun scripts/bundle-workflows.ts",
    "validate:workflow-exports": "tsx scripts/validate-workflow-exports.ts",
    "debug:workflows": "tsx scripts/workflow-debug-helper.ts",
    "start": "node --enable-source-maps dist/index.js",
    "start:bun": "bun dist/index.js",
    "start:temporal": "node --enable-source-maps dist/temporal/main.temporal.js",
    "validate:secrets": "bun run src/lib/env/index.ts",
    "dev:email": "DEBUG= LOG_LEVEL=${LOG_LEVEL:-debug} bun run with-env run dev:email:internal",
    "dev:email:internal": "ENVIRONMENT=${ENVIRONMENT:-local} EMAIL_TRACKING_JWT_SECRET=${EMAIL_TRACKING_JWT_SECRET:---dev-jwt-secret--} LOG_LEVEL=${LOG_LEVEL:-debug} email dev --port ${EMAIL_PREVIEW_PORT:-3005} --dir src/mail/templates",
    "command:get-nft-updates": "tsx src/scripts/get-nft-updates.ts",
    "command:send-test-email": "tsx src/scripts/send-test-email.tsx",
    "command:test-email-campaigns": "tsx src/scripts/test-email-campaigns.tsx",
    "command:trigger-nft-updates-workflow": "tsx src/scripts/trigger-nft-updates-workflow.ts",
    "command:trigger-nft-updates-schedule": "tsx src/scripts/trigger-nft-updates-schedule.ts",
    "command:email-templates": "tsx src/scripts/email-templates-cli.ts",
    "command:setup-nft-report-schedule": "tsx src/scripts/setup-nft-management-report-schedule.ts",
    "command:analytics": "tsx src/scripts/analytics-cli.ts",
    "command:migrate-mongo-ai-data": "tsx src/scripts/migrate-mongo-ai-data.ts",
    "command:migrate-mongo-ai-data-standalone": "tsx src/lib/legacy/namefi-gpt/migrate-from-mongo-original.ts",
    "command:disable-auto-renewal": "tsx src/scripts/disable-auto-renewal.ts",
    "command:backfill-x402-signature-encryption": "tsx src/scripts/backfill-x402-signature-encryption.ts",
    "command:test-disable-auto-renewal": "tsx src/scripts/test-disable-auto-renewal.ts",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.830.0",
    "@c15t/backend": "^1.8.0",
    "@date-fns/tz": "^1.3.1",
    "@date-fns/utc": "^2.1.1",
    "@google-analytics/admin": "^8.3.0",
    "@google-analytics/data": "^5.2.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/dns": "^5.3.0",
    "@hono/node-server": "^1.14.0",
    "@hono/trpc-server": "^0.3.4",
    "@inquirer/prompts": "^7.6.0",
    "@keyv/postgres": "^2.2.3",
    "@namefi-astra/ai": "workspace:*",
    "@namefi-astra/common": "workspace:*",
    "@namefi-astra/coredns-client": "workspace:*",
    "@namefi-astra/db": "workspace:*",
    "@namefi-astra/dns-tools": "workspace:*",
    "@namefi-astra/env": "workspace:*",
    "@namefi-astra/indexer": "workspace:*",
    "@namefi-astra/registrars": "workspace:*",
    "@namefi-astra/storage": "workspace:*",
    "@namefi-astra/utils": "workspace:*",
    "@namefi-astra/zod-dns": "workspace:*",
    "@namefi/cat": "^1.0.0-beta.8",
    "@neondatabase/serverless": "^0.10.4",
    "@orpc/contract": "^1.13.2",
    "@orpc/json-schema": "^1.13.2",
    "@orpc/openapi": "^1.13.2",
    "@orpc/server": "^1.13.2",
    "@orpc/shared": "^1.13.2",
    "@orpc/trpc": "^1.13.2",
    "@orpc/zod": "^1.13.2",
    "@ponder/client": "0.16.6",
    "@privy-io/server-auth": "^1.19.2",
    "@react-email/components": "^0.0.34",
    "@react-email/render": "^1.4.0",
    "@samyx/drizzler-filters-sorters": "^0.0.5",
    "@scalar/hono-api-reference": "^0.9.30",
    "@temporalio/activity": "1.13.1",
    "@temporalio/client": "1.13.1",
    "@temporalio/common": "1.13.1",
    "@temporalio/worker": "1.13.1",
    "@temporalio/workflow": "1.13.1",
    "@trpc/server": "^11.4.4",
    "@valora/viem-account-hsm-gcp": "^1.2.2",
    "@vercel/sdk": "^1.10.6",
    "@x402/core": "^2.0.0",
    "@x402/evm": "^2.0.0",
    "@x402/hono": "^2.0.0",
    "@x402/paywall": "^2.0.0",
    "altcha-lib": "^1.3.0",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "bignumber.js": "^9.1.2",
    "bottleneck": "^2.19.5",
    "caip": "^1.1.1",
    "change-case": "^5.4.4",
    "commander": "^14.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.6",
    "drizzle-zod": "^0.8.3",
    "entities": "^6.0.1",
    "hono": "^4.12.8",
    "hono-pino-logger": "^1.0.0",
    "hono-rate-limiter": "^0.4.2",
    "iso-countries-lookup": "^2.0.8",
    "jose": "^6.0.12",
    "keyv": "^5.6.0",
    "limiter": "^2.1.0",
    "mnemonist": "^0.40.3",
    "mppx": "^0.4.7",
    "nodemailer": "^6.10.0",
    "openai": "^5.12.2",
    "p-map": "^7.0.3",
    "p-props": "^6.0.0",
    "parse-domain": "^8.2.2",
    "pg": "^8.15.6",
    "pino": "^9.6.0",
    "pino-opentelemetry-transport": "^1.0.1",
    "pino-pretty": "^13.0.0",
    "pluralize": "^8.0.0",
    "prom-client": "^15.1.3",
    "ramda": "^0.30.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^4.3.2",
    "react-markdown": "^10.1.0",
    "redis": "^5.11.0",
    "rehype-external-links": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "superjson": "^2.2.2",
    "tldts": "^7.0.8",
    "unique-names-generator": "^4.7.1",
    "viem": "2.47.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@react-email/preview-server": "4.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.13.14",
    "@types/nodemailer": "^6.4.17",
    "@types/pluralize": "^0.0.33",
    "@types/ramda": "^0.30.2",
    "@types/react": "19.2.2",
    "drizzle-kit": "^0.31.5",
    "neonctl": "^2.9.0",
    "tsdown": "^0.21.0-beta.2",
    "tsx": "^4.19.3",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "peerDependencies": {
    "@vitest/coverage-v8": "^3.1.2",
    "vitest": "^3.1.2"
  }
}
