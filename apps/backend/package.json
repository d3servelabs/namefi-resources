{
  "name": "@namefi-astra/backend",
  "version": "0.3.0-beta",
  "type": "module",
  "exports": {
    "./trpc": "./src/trpc/index.ts",
    "./trpc/types": "./src/trpc/types.ts"
  },
  "imports": {
    "#lib/env": "./src/lib/env/index.ts",
    "#lib/*": "./src/lib/*.ts",
    "#services/*": "./src/services/*.ts",
    "#temporal/*": "./src/temporal/*.ts",
    "#temporal/shared/*": "./src/temporal/shared/*.ts",
    "#temporal/shared": "./src/temporal/shared/index.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist .react-email",
    "force-local": "ENVIRONMENT=local LOG_LEVEL=debug bun",
    "dev": "bun run force-local tsx watch src/index.ts",
    "dev:temporal": "wait-on tcp:${TEMPORAL_SERVER_PORT:-7233} && bun run force-local tsx watch src/temporal/main.temporal.ts",
    "trpc": "tsx watch src/trpc/main.ts",
    "with-env": "infisical run --token=$INFISICAL_SERVICE_TOKEN -- bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "bun --env-file .env.test test",
    "test:watch": "bun --env-file .env.test vitest",
    "test:coverage": "bun --env-file .env.test test --coverage --coverage-reporter=lcov",
    "test:ci": "cd ../.. && act -j test --input package_filter=\"@namefi-astra/backend\" --container-architecture linux/amd64",
    "build": "tsup",
    "build:prod": "NODE_ENV=production tsup",
    "bundle:workflows": "tsx scripts/bundle-workflows.ts",
    "validate:workflow-exports": "tsx scripts/validate-workflow-exports.ts",
    "debug:workflows": "tsx scripts/workflow-debug-helper.ts",
    "start": "node dist/index.js",
    "start:bun": "bun dist/index.js",
    "start:temporal": "node dist/temporal/main.temporal.js",
    "validate:secrets": "bun run with-env src/lib/env/index.ts",
    "dev:email": "email dev --port 3005 --dir src/mail/templates",
    "command:get-nft-updates": "tsx src/scripts/get-nft-updates.ts",
    "command:send-test-email": "tsx src/scripts/send-test-email.tsx",
    "command:trigger-nft-updates-workflow": "tsx src/scripts/trigger-nft-updates-workflow.ts",
    "command:trigger-nft-updates-schedule": "tsx src/scripts/trigger-nft-updates-schedule.ts",
    "command:email-templates": "tsx src/scripts/email-templates-cli.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.830.0",
    "@aws-sdk/client-route-53": "^3.830.0",
    "@hono/node-server": "^1.14.0",
    "@hono/trpc-server": "^0.3.4",
    "@inquirer/prompts": "^7.6.0",
    "@namefi-astra/ai": "workspace:*",
    "@namefi-astra/db": "workspace:*",
    "@namefi-astra/dns-tools": "workspace:*",
    "@namefi-astra/env": "workspace:*",
    "@namefi-astra/registrars": "workspace:*",
    "@namefi-astra/storage": "workspace:*",
    "@namefi-astra/utils": "workspace:*",
    "@namefi-astra/zod-dns": "workspace:*",
    "@namefi/cat": "^1.0.0-beta.8",
    "@neondatabase/serverless": "^0.10.4",
    "@privy-io/server-auth": "^1.19.2",
    "@react-email/components": "^0.3.1",
    "@react-email/render": "^1.1.3",
    "@temporalio/activity": "^1.11.7",
    "@temporalio/client": "^1.11.7",
    "@temporalio/common": "^1.11.7",
    "@temporalio/worker": "^1.11.7",
    "@temporalio/workflow": "^1.11.7",
    "@trpc/server": "^11.0.1",
    "@valora/viem-account-hsm-gcp": "^1.2.2",
    "axios": "^1.9.0",
    "bignumber.js": "^9.1.2",
    "change-case": "^5.4.4",
    "commander": "^14.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.1",
    "drizzle-zod": "^0.7.0",
    "hono": "^4.7.5",
    "hono-pino-logger": "^1.0.0",
    "iso-countries-lookup": "^2.0.8",
    "mnemonist": "^0.40.3",
    "mongoose": "^8.16.0",
    "nodemailer": "^6.10.0",
    "p-map": "^7.0.3",
    "parse-domain": "^8.2.2",
    "pg": "^8.15.6",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ramda": "^0.30.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-email": "^4.2.1",
    "react-markdown": "^10.1.0",
    "rehype-external-links": "^3.0.0",
    "stripe": "^17.7.0",
    "superjson": "^2.2.2",
    "tldts": "^7.0.8",
    "unique-names-generator": "^4.7.1",
    "viem": "^2.24.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@react-email/preview-server": "^4.2.1",
    "@types/node": "^22.13.14",
    "@types/nodemailer": "^6.4.17",
    "@types/ramda": "^0.30.2",
    "drizzle-kit": "^0.30.6",
    "neonctl": "^2.9.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "peerDependencies": {
    "@vitest/coverage-v8": "^3.1.2",
    "vitest": "^3.1.2"
  }
}
