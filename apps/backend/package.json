{
  "name": "@namefi-astra/backend",
  "type": "module",
  "exports": {
    "./trpc": "./src/trpc/index.ts",
    "./lib/db/types": "./src/lib/db/types.ts"
  },
  "imports": {
    "#lib/env": "./src/lib/env/index.ts",
    "#lib/*": "./src/lib/*.ts",
    "#services/*": "./src/services/*.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:temporal": "tsx watch src/temporal/main.temporal.ts",
    "trpc": "tsx watch src/trpc/main.ts",
    "with-env": "infisical run --token=$INFISICAL_SERVICE_TOKEN -- bun run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "build:prod": "NODE_ENV=production tsup",
    "start": "node dist/index.js",
    "start:bun": "bun dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/swagger-ui": "^0.5.1",
    "@hono/trpc-server": "^0.3.4",
    "@hono/zod-openapi": "^0.19.2",
    "@namefi-astra/db": "workspace:*",
    "@namefi-astra/env": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "@privy-io/server-auth": "^1.18.12",
    "@temporalio/activity": "^1.11.7",
    "@temporalio/client": "^1.11.7",
    "@temporalio/worker": "^1.11.7",
    "@temporalio/workflow": "^1.11.7",
    "@trpc/server": "^11.0.0-rc.824",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.40.0",
    "drizzle-zod": "^0.7.0",
    "hono": "^4.7.4",
    "ramda": "^0.30.1",
    "stripe": "^17.7.0",
    "superjson": "^2.2.2",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@types/node": "^20.11.17",
    "@types/ramda": "^0.30.2",
    "@types/ws": "^8.5.14",
    "drizzle-kit": "^0.30.5",
    "tsup": "^8.4.0",
    "tsx": "^4.7.1"
  }
}
