{
  "name": "@namefi-astra/backend",
  "type": "module",
  "exports": {
    "./trpc": "./src/trpc/index.ts",
    "./lib/db/types": "./src/lib/db/types.ts"
  },
  "imports": {
    "#lib/env": "./src/lib/env/index.ts",
    "#lib/*": "./src/lib/*.ts",
    "#services/*": "./src/services/*.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:temporal": "tsx watch src/temporal/main.temporal.ts",
    "trpc": "tsx watch src/trpc/main.ts",
    "with-env": "infisical run --token=$INFISICAL_SERVICE_TOKEN -- bun run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test bun test",
    "test:watch": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test bun test --coverage",
    "test:ci": "cd ../.. && act -j test --input package_filter=\"@namefi-astra/backend\" --container-architecture linux/amd64",
    "build": "tsup",
    "build:prod": "NODE_ENV=production tsup",
    "bundle:workflows": "tsx scripts/bundle-workflows.ts",
    "start": "node dist/index.js",
    "start:bun": "bun dist/index.js",
    "start:temporal": "node dist/temporal/main.temporal.js",
    "validate:secrets": "bun run with-env src/lib/env/index.ts",
    "dev:email": "email dev --port 5050 --dir src/mail/templates"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/swagger-ui": "^0.5.1",
    "@hono/trpc-server": "^0.3.4",
    "@hono/zod-openapi": "^0.19.2",
    "@namefi-astra/db": "workspace:*",
    "@namefi-astra/env": "workspace:*",
    "@namefi-astra/utils": "workspace:*",
    "@namefi-astra/zod-dns": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "@privy-io/server-auth": "^1.19.2",
    "@react-email/components": "^0.0.34",
    "@temporalio/activity": "^1.11.7",
    "@temporalio/client": "^1.11.7",
    "@temporalio/worker": "^1.11.7",
    "@temporalio/workflow": "^1.11.7",
    "@trpc/server": "^11.0.1",
    "@valora/viem-account-hsm-gcp": "^1.2.2",
    "bignumber.js": "^9.1.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.1",
    "drizzle-zod": "^0.7.0",
    "hono": "^4.7.5",
    "nodemailer": "^6.10.0",
    "p-all": "^5.0.0",
    "p-map": "^7.0.3",
    "p-props": "^6.0.0",
    "parse-domain": "^8.2.2",
    "ramda": "^0.30.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-email": "^4.0.2",
    "react-markdown": "^10.1.0",
    "rehype-external-links": "^3.0.0",
    "stripe": "^17.7.0",
    "superjson": "^2.2.2",
    "unique-names-generator": "^4.7.1",
    "viem": "^2.24.2",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@types/node": "^22.13.14",
    "@types/nodemailer": "^6.4.17",
    "@types/ramda": "^0.30.2",
    "@types/ws": "^8.18.0",
    "@vitest/coverage-v8": "^3.1.1",
    "drizzle-kit": "^0.30.6",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.1"
  }
}
