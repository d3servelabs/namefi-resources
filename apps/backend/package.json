{
	"name": "@namefi-astra/backend",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"format": "biome check --write",
		"with-env": "infisical run --token=$INFISICAL_SERVICE_TOKEN -- bun run",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.8",
		"@hono/swagger-ui": "^0.5.1",
		"@hono/zod-openapi": "^0.19.2",
		"@neondatabase/serverless": "^0.10.4",
		"dotenv": "^16.4.7",
		"drizzle-orm": "^0.40.0",
		"drizzle-zod": "^0.7.0",
		"hono": "^4.7.2",
		"ws": "^8.18.1",
		"znv": "^0.4.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@namefi-astra/biome": "workspace:*",
		"@namefi-astra/typescript": "workspace:*",
		"@types/node": "^20.11.17",
		"@types/ws": "^8.5.14",
		"drizzle-kit": "^0.30.5",
		"tsx": "^4.7.1"
	}
}
