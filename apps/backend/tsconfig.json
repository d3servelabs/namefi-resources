{
  "extends": "@namefi-astra/typescript",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "#lib/*": ["./src/lib/*"]
    }
  },
  "include": ["global.ts", "src/**/*.ts"]
}
