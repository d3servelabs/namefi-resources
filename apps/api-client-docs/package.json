{
  "name": "api-client-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist .react-email",
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "typecheck": "bun run types:check",
    "next:typegen": "next typegen",
    "types:check": "fumadocs-mdx && bun run next:typegen && tsgo --noEmit",
    "postinstall": "fumadocs-mdx",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "fumadocs-core": "16.7.11",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-openapi": "10.6.7",
    "fumadocs-ui": "16.7.11",
    "lucide-react": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shiki": "^3.21.0",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.7",
    "@namefi-astra/typescript": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@types/mdx": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "json-schema-typed": "^8.0.2",
    "openapi-types": "^12.1.3",
    "postcss": "catalog:",
    "tailwindcss": "catalog:"
  }
}
