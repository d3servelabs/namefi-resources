{
  "extends": "@namefi-astra/typescript",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@namefi-astra/ui/components/namefi/namefi-button": [
        "../../packages/ui/src/components/namefi/namefi-button.tsx"
      ],
      "@namefi-astra/ui/components/namefi/progress-timeline": [
        "../../packages/ui/src/components/namefi/progress-timeline/index.ts"
      ],
      "@namefi-astra/ui/components/shadcn": [
        "../../packages/ui/src/components/shadcn"
      ],
      "@namefi-astra/ui/components/shadcn/*": [
        "../../packages/ui/src/components/shadcn/*"
      ],
      "@namefi-astra/ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@namefi-astra/ui/lib/*": ["../../packages/ui/src/lib/*"]
    },
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "next.config.mjs"
  ],
  "exclude": ["node_modules"]
}
