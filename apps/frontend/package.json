{
  "name": "@namefi-astra/frontend",
  "version": "3.3.220-beta",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "force-local": "ENVIRONMENT=local bun",
    "dev": "ENVIRONMENT=local next dev --port ${FRONTEND_PORT:-5050}",
    "dev:internal": "ENVIRONMENT=local next dev --port ${FRONTEND_PORT:-5050}",
    "dev:remote": "next dev --port ${FRONTEND_PORT:-5050}",
    "with-env": "infisical run --token=$INFISICAL_SERVICE_TOKEN -- bun",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsgo --noEmit",
    "validate:secrets": "bun run src/lib/env/validate-secrets.ts",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook --url http://127.0.0.1:6006",
    "test-storybook:ci": "concurrently -k -s first -n SB,TEST \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && bun run test-storybook\"",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN"
  },
