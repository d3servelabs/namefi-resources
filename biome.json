{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": []
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "all": true,
      "complexity": {
        "noUselessSwitchCase": "warn"
      },
      "performance": {
        "noBarrelFile": "off",
        "noReExportAll": "off",
        "useTopLevelRegex": "off"
      },
      "correctness": {
        "noNodejsModules": "off",
        "useImportExtensions": "off",
        "noUndeclaredDependencies": "off"
      },
      "style": {
        "noDefaultExport": "off",
        "useNamingConvention": "off",
        "useFilenamingConvention": "off",
        "noNamespaceImport": "off",
        "useSingleCaseStatement": "off"
      },
      "suspicious": {
        "noExplicitAny": "info",
        "noEmptyBlockStatements": "off",
        "noReactSpecificProps": "off",
        "noConsoleLog": "off",
        "noConsole": "off",
        "noArrayIndexKey": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  }
}
