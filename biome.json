{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": []
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "all": true,
      "complexity": {
        "noUselessSwitchCase": "warn",
        "noExcessiveCognitiveComplexity": "info",
        "noForEach": "info"
      },
      "performance": {
        "noBarrelFile": "info",
        "noReExportAll": "info",
        "useTopLevelRegex": "info"
      },
      "correctness": {
        "noNodejsModules": "info",
        "useImportExtensions": "info",
        "noUndeclaredDependencies": "info"
      },
      "style": {
        "noDefaultExport": "info",
        "useNamingConvention": "info",
        "useFilenamingConvention": "info",
        "noNamespaceImport": "info",
        "useSingleCaseStatement": "info"
      },
      "suspicious": {
        "noExplicitAny": "info",
        "noEmptyBlockStatements": "info",
        "noReactSpecificProps": "info",
        "noConsoleLog": "info",
        "noConsole": "info",
        "noArrayIndexKey": "info"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  }
}
