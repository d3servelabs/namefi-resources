{
  "extends": "@namefi-astra/typescript",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "#/lib/env": ["./src/lib/env/index.ts"],
      "#/lib/*": ["./src/lib/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
