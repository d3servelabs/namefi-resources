{
  "name": "@namefi-astra/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./*": [
      "./src/*.ts"
    ],
    "./types-extensions": "./src/types-extensions/index.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "typecheck": "tsgo --noEmit",
    "test": "vitest --run",
    "test:coverage": "bun vitest run --coverage",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@namefi-astra/zod-dns": "workspace:*",
    "date-fns": "^4.1.0",
    "parse-domain": "^8.2.2",
    "ramda": "^0.30.1",
    "viem": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@types/ramda": "^0.30.2",
    "vitest": "^3.2.6"
  }
}
