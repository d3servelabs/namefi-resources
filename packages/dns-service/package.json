{
  "name": "@namefi-astra/dns-service",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./routers/dns": "./src/routers/dns/index.ts",
    "./lib/env": "./src/lib/env/index.ts",
    "./*": "./src/*.ts"
  },
  "imports": {
    "#lib/env": "./src/lib/env/index.ts",
    "#lib/*": "./src/lib/*.ts",
    "#services/*": "./src/services/*.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "typecheck": "tsgo --noEmit",
    "test": "bun --env-file .env.test vitest run",
    "test:watch": "bun --env-file .env.test vitest",
    "test:coverage": "bun --env-file .env.test vitest run --coverage",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@namefi-astra/common": "workspace:*",
    "@namefi-astra/db": "workspace:*",
    "@namefi-astra/env": "workspace:*",
    "@namefi-astra/registrars": "workspace:*",
    "@namefi-astra/utils": "workspace:*",
    "@namefi-astra/zod-dns": "workspace:*",
    "@trpc/server": "^11.8.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "jose": "^6.0.12",
    "lru-cache": "^11.1.0",
    "mnemonist": "^0.40.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ramda": "^0.30.1",
    "redis": "^5.11.0",
    "superjson": "^2.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@types/node": "^22.13.14",
    "@types/ramda": "^0.30.2"
  },
  "peerDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "vitest": "^3.2.6"
  }
}
