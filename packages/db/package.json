    "@types/node": "^20.11.17",
    "@types/ws": "^8.5.14",
    "drizzle-kit": "^0.30.5"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.40.0",
    "drizzle-zod": "^0.7.0"
  }
