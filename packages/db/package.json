{
  "name": "@namefi-astra/db",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./types": "./src/types.ts",
    "./schemas/internal": "./src/schemas/internal.ts",
    "./schemas/managed-indexer-data": "./src/schemas/managed-indexer-data/index.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "with-env": "infisical run --token=$INFISICAL_SERVICE_TOKEN -- bun",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsgo --noEmit",
    "validate:secrets": "bun run with-env src/lib/env/index.ts",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@c15t/backend": "^2.1.0",
    "@namefi-astra/common": "workspace:*",
    "@namefi-astra/env": "workspace:*",
    "@namefi-astra/utils": "workspace:*",
    "@namefi-astra/zod-dns": "workspace:*",
    "@samyx/drizzler-utils": "^0.0.1",
    "bufferutil": "^4.0.9",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "ws": "^8.18.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.0",
    "drizzle-kit": "^0.31.5"
  },
  "optionalDependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "pg": "^8.15.6"
  }
}
