{
  "name": "@namefi-astra/zod-dns",
  "author": "Namefi Open Source <oss@namefi.io>",
  "license": "MIT",
  "description": "Zod schemas for DNS created and maintained by Namefi Team",
  "version": "0.0.0-pre.3",
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "typecheck": "tsgo --noEmit",
    "test": "vitest --run",
    "test:coverage": "bun vitest run --coverage",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@namefi-astra/typescript": "workspace:*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "peerDependencies": {
    "vitest": "^3.1.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*"
  }
}
