{
  "name": "@namefi-astra/env",
  "type": "module",
  "sideEffects": true,
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "typecheck": "tsgo --noEmit",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@infisical/sdk": "^4.0.4",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*"
  },
  "peerDependencies": {
    "zod": "catalog:"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./preload": "./src/preload.ts",
    "./preload-sync": "./src/preload-sync.ts",
    "./infisical": "./src/infisical.ts"
  }
}
