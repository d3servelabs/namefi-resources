{
  "name": "@namefi-astra/ai",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/client.ts"
  },
  "scripts": {
    "lint": "bun run typecheck",
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "with-env": "infisical run --token=$INFISICAL_SERVICE_TOKEN -- bun",
    "typecheck": "tsc --noEmit",
    "validate:secrets": "bun run with-env src/env/index.ts",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.0-beta.39",
    "@ai-sdk/openai": "^3.0.0-beta.52",
    "@namefi-astra/env": "workspace:*",
    "@namefi-astra/storage": "workspace:*",
    "@namefi-astra/utils": "workspace:*",
    "ai": "^6.0.0-beta.93",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*"
  }
}
