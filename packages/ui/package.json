    "cmdk": "catalog:",
    "embla-carousel-react": "catalog:",
    "lucide-react": "catalog:",
    "next-themes": "catalog:",
    "react-day-picker": "catalog:",
    "react-hook-form": "catalog:",
    "shadcn": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tailwindcss": "catalog:"
  }
}
