    "./components/namefi/progress-timeline": "./src/components/namefi/progress-timeline/index.ts",
    "./components/namefi/gradient-card": "./src/components/namefi/gradient-card.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./styles/globals.css": "./src/styles/globals.css"
  },
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "typecheck": "tsgo --noEmit",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe ."
