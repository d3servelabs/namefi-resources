{
  "name": "@namefi-astra/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./components/shadcn/*": "./src/components/shadcn/*.tsx",
    "./components/namefi/brand-icons": "./src/components/namefi/brand-icons.tsx",
    "./components/namefi/namefi-button": "./src/components/namefi/namefi-button.tsx",
