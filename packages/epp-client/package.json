{
  "name": "@namefi-astra/epp-client",
  "version": "0.0.0-alpha.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./data": "./src/data/index.ts",
    "./data/*": "./src/data/*.ts",
    "./utils/*": "./src/utils/*.ts"
  },
  "imports": {
    "#lib/env": "./src/lib/env/index.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .next .turbo node_modules out dist",
    "typecheck": "tsc --noEmit",
    "test": "bun --env-file .env.test test",
    "test:watch": "bun --env-file .env.test vitest",
    "test:coverage": "bun --env-file .env.test test --coverage --coverage-reporter=lcov",
    "command:epp:repl": "tsx src/cli/epp-shell.ts",
    "command:epp:interactive": "tsx src/cli/epp-shell.ts interactive",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@date-fns/tz": "^1.3.1",
    "@date-fns/utc": "^2.1.1",
    "@inquirer/prompts": "^7.6.0",
    "axios": "^1.9.0",
    "bottleneck": "^2.19.5",
    "change-case": "^5.4.4",
    "commander": "^14.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^5.0.0",
    "generic-pool": "^3.9.0",
    "iso-countries-lookup": "^2.0.8",
    "libxmljs": "^1.0.11",
    "libxslt": "^0.10.2",
    "limiter": "^2.1.0",
    "p-map": "^7.0.3",
    "p-props": "^6.0.0",
    "parse-domain": "^8.2.2",
    "pino": "^9.6.0",
    "pino-opentelemetry-transport": "^1.0.1",
    "pino-pretty": "^13.0.0",
    "pluralize": "^8.0.0",
    "ramda": "^0.30.1",
    "superjson": "^2.2.2",
    "tldts": "^7.0.8",
    "unique-names-generator": "^4.7.1",
    "xml-formatter": "^3.6.7",
    "yaml": "^2.8.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@namefi-astra/typescript": "workspace:*",
    "@types/generic-pool": "^3.8.3",
    "@types/libxslt": "^0.9.5",
    "@types/node": "^22.13.14",
    "@types/pluralize": "^0.0.33",
    "@types/ramda": "^0.30.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "peerDependencies": {
    "@vitest/coverage-v8": "^3.1.2",
    "vitest": "^3.1.2"
  }
}
