{
  "$schema": "https://beta.frontmatter.codes/frontmatter.schema.json",
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "author",
      "fields": [
        {
          "title": "name",
          "name": "name",
          "type": "string"
        },
        {
          "title": "avatar",
          "name": "avatar",
          "type": "string"
        },
        {
          "title": "occupation",
          "name": "occupation",
          "type": "string"
        },
        {
          "title": "company",
          "name": "company",
          "type": "string"
        },
        {
          "title": "twitter",
          "name": "twitter",
          "type": "string"
        },
        {
          "title": "linkedin",
          "name": "linkedin",
          "type": "string"
        },
        {
          "title": "language",
          "name": "language",
          "type": "choice",
          "choices": ["en", "de", "fr", "es", "zh", "ar", "hi"]
        }
      ]
    },
    {
      "name": "content",
      "pageBundle": false,
      "fields": [
        {
          "title": "title",
          "name": "title",
          "type": "string"
        },
        {
          "title": "date",
          "name": "date",
          "type": "datetime",
          "dateFormat": "YYYY-MM-DD",
          "isPublishDate": true,
          "default": "{{now}}"
        },
        {
          "title": "language",
          "name": "language",
          "type": "choice",
          "choices": ["en", "de", "fr", "es", "zh", "ar", "hi"]
        },
        {
          "title": "tags",
          "name": "tags",
          "type": "tags"
        },
        {
          "title": "authors",
          "name": "authors",
          "type": "list",
          "default": ["namefiteam"]
        },
        {
          "title": "draft",
          "name": "draft",
          "type": "draft"
        },
        {
          "title": "description",
          "name": "description",
          "type": "string"
        },
        {
          "title": "keywords",
          "name": "keywords",
          "type": "list"
        }
      ]
    }
  ],
  "frontMatter.framework.id": "next",
  "frontMatter.content.publicFolder": "public/assets",
  "frontMatter.preview.host": "http://localhost:3000",
  "frontMatter.content.pageFolders": [
    {
      "title": "Blog",
      "path": "[[workspace]]/apps/resources/data/blog",
      "filePrefix": "",
      "defaultLocale": "en",
      "previewPath": "/r/{{locale}}/blog",
      "contentTypes": ["content"]
    },
    {
      "title": "Glossary",
      "path": "[[workspace]]/apps/resources/data/glossary",
      "filePrefix": "",
      "defaultLocale": "en",
      "previewPath": "/r/{{locale}}/glossary",
      "contentTypes": ["content"]
    },
    {
      "title": "Partners",
      "path": "[[workspace]]/apps/resources/data/partners",
      "filePrefix": "",
      "defaultLocale": "en",
      "previewPath": "/r/{{locale}}/partners",
      "contentTypes": ["content"]
    },
    {
      "title": "TLDs",
      "path": "[[workspace]]/apps/resources/data/tld",
      "filePrefix": "",
      "defaultLocale": "en",
      "previewPath": "/r/{{locale}}/tld",
      "contentTypes": ["content"]
    },
    {
      "title": "Authors",
      "path": "[[workspace]]/apps/resources/data/authors",
      "filePrefix": "",
      "defaultLocale": "en",
      "contentTypes": ["author"]
    }
  ],
  "frontMatter.framework.startCommand": "cd apps/resources &&  bunx next dev",
  "frontMatter.git.commitMessage": "feat: synced by Front Matter",
  "frontMatter.content.i18n": [
    {
      "title": "English",
      "locale": "en",
      "path": "en"
    },
    {
      "title": "German",
      "locale": "de",
      "path": "de"
    },
    {
      "title": "French",
      "locale": "fr",
      "path": "fr"
    },
    {
      "title": "Spanish",
      "locale": "es",
      "path": "es"
    },
    {
      "title": "Chinese",
      "locale": "zh",
      "path": "zh"
    },
    {
      "title": "Arabic",
      "locale": "ar",
      "path": "ar"
    },
    {
      "title": "Hindi",
      "locale": "hi",
      "path": "hi"
    }
  ],
  "frontMatter.dashboard.openOnStart": false
}
