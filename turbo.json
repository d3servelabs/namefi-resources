{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": ["NODE_ENV", "CI"]
    },
    "test:watch": {
      "dependsOn": ["^build"],
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "@namefi-astra/backend#build": {
      "dependsOn": ["transit"],
      "env": ["*"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!**/*.spec.*"],
      "outputs": ["dist/**", "build/**"]
    },
    "@namefi-astra/frontend#build": {
      "dependsOn": ["transit"],
      "env": ["*"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!src/stories/**",
        "!**/*.stories.*",
        "!**/*.test.*",
        "!**/*.spec.*",
        "!.storybook/**"
      ],
      "outputs": ["dist/**", ".next/**", "build/**", "!.next/cache/**"]
    },
    "build": {
      "dependsOn": ["^build", "transit"],
      "env": ["*"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!src/stories/**",
        "!**/*.stories.*",
        "!**/*.test.*",
        "!**/*.spec.*",
        "!.storybook/**"
      ],
      "outputs": ["dist/**", ".next/**", "build/**", "!.next/cache/**"]
    },
    "validate:secrets": {
      "env": ["*"],
      "cache": false
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "check:error": {
      "dependsOn": ["^check:error"]
    },
    "check:unsafe": {
      "dependsOn": ["^check:unsafe"]
    },
    "clean": {
      "cache": false
    }
  }
}
