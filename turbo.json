{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": ["NODE_ENV", "CI"]
    },
    "test:watch": {
      "dependsOn": ["^build"],
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "@namefi-astra/backend#build": {
      "dependsOn": [],
      "env": ["*"],
      "outputs": ["dist/**", "build/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "env": ["*"],
      "outputs": ["dist/**", ".next/**", "build/**", "!.next/cache/**"]
    },
    "validate:secrets": {
      "env": ["*"],
      "cache": false
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "check:error": {
      "dependsOn": ["^check:error"]
    },
    "check:unsafe": {
      "dependsOn": ["^check:unsafe"]
    },
    "clean": {}
  }
}
