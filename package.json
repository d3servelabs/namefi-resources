{
  "name": "namefi-astra",
  "private": true,
  "workspaces": [
    "apps/*",
    "tooling/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.13.1"
  },
  "packageManager": "bun@1.3.1",
  "devDependencies": {
    "@ast-grep/cli": "^0.18.0",
    "@biomejs/biome": "^2.2.7",
    "@infisical/cli": "^0.40.0",
    "@vitest/coverage-v8": "^3.1.2",
    "concurrently": "^9.1.2",
    "knip": "^5.64.2",
    "lefthook": "^1.11.6",
    "turbo": "^2.5.8",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  },
  "overrides": {
    "date-fns": "4.1.0"
  },
  "scripts": {
    "clean:workspaces": "turbo clean",
    "clean:root": "git clean -xdf node_modules out .turbo .next",
    "clean:all": "bun run clean:root && bun run clean:workspaces",
    "fix-infisical": "bun --cwd node_modules/@infisical/cli preinstall",
    "link-infisical": "bun run scripts/link-infisical.ts",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "dev:backend:api": "bun --cwd=apps/backend dev",
    "dev:backend:email": "bun --cwd=apps/backend dev:email",
    "dev:backend:temporal": "bun --cwd=apps/backend dev:temporal",
    "dev:temporal-server": "temporal server start-dev --db-filename ./.namefi-astra-local-temporal.db",
    "dev:frontend": "bun --cwd=apps/frontend dev",
    "dev": "concurrently -n 'backend:api,frontend,backend:email,temporal:server,temporal:worker' -c 'blue.bold,green.bold,yellow.bold,red.bold,cyan.bold' \"bun run dev:backend:api\" \"bun run dev:frontend\" \"bun run dev:backend:email\" \"bun run dev:temporal-server\" \"bun run dev:backend:temporal\"",
    "dev:base": "concurrently -n 'backend:api,frontend' -c 'blue.bold,red.bold' \"bun run dev:backend:api\" \"bun run dev:frontend\"",
    "typecheck": "turbo typecheck",
    "test": "NODE_ENV=test turbo test",
    "test:watch": "NODE_ENV=test turbo test:watch",
    "test:coverage": "NODE_ENV=test turbo test:coverage",
    "sherif": "bunx sherif@latest",
    "sherif:fix": "bunx sherif@latest -f",
    "test:ci": "act -j test --container-architecture linux/amd64",
    "test:ci:dry": "act -j test -n",
    "sgr": "bun run scripts/run-sgr.ts scan *",
    "sgr:fix": "bun run scripts/run-sgr.ts scan --fix *",
    "validate": "concurrently -n 'typecheck,biome,sherif,sgr' -c 'blue.bold,green.bold,yellow.bold,red.bold' \"turbo typecheck\" \"bun check:error\" \"bun sherif\" \"bun sgr\"",
    "validate:secrets": "turbo validate:secrets",
    "knip": "bunx knip"
  },
  "trustedDependencies": [
    "@ast-grep/cli",
    "@biomejs/biome",
    "@infisical/cli",
    "@reown/appkit",
    "@swc/core",
    "@tailwindcss/oxide",
    "@temporalio/core-bridge",
    "bufferutil",
    "esbuild",
    "keccak",
    "lefthook",
    "protobufjs",
    "sharp",
    "utf-8-validate"
  ]
}
