{
  "name": "namefi-astra",
  "private": true,
  "workspaces": [
    "apps/*",
    "tooling/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.13.1"
  },
  "packageManager": "bun@1.3.1",
  "devDependencies": {
    "@ast-grep/cli": "^0.18.0",
    "@biomejs/biome": "^2.2.7",
    "@infisical/cli": "^0.43.16",
    "@vitest/coverage-v8": "^3.1.2",
    "concurrently": "^9.1.2",
    "knip": "^5.64.2",
    "lefthook": "^1.11.6",
    "playwright": "^1.57.0",
    "turbo": "^2.5.8",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3",
    "webpack": "5.99.9"
  },
  "overrides": {
    "date-fns": "4.1.0",
    "webpack": "5.99.9"
  },
  "scripts": {
    "clean:workspaces": "turbo clean",
    "clean:root": "git clean -xdf node_modules out .turbo .next",
    "clean:all": "bun run clean:workspaces && bun run clean:root",
    "prepare": "sh scripts/prepare.sh",
    "rulesync:generate": "bunx --yes rulesync@latest generate -c rulesync.jsonc --simulate-skills",
    "fix-infisical": "bun --cwd node_modules/@infisical/cli preinstall",
    "link-infisical": "bun run scripts/link-infisical.ts",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "dev:backend:api": "bun run scripts/dev/run.ts --backend-only",
    "dev:backend:api:internal": "bun --cwd=apps/backend dev:internal",
    "dev:backend:email": "bun --cwd=apps/backend dev:email",
    "dev:backend:email:internal": "bun --cwd=apps/backend dev:email:internal",
    "dev:backend:temporal": "bun --cwd=apps/backend dev:temporal",
    "dev:backend:temporal:internal": "bun --cwd=apps/backend dev:temporal:internal",
    "dev:temporal-server": "temporal server start-dev --port ${TEMPORAL_SERVER_PORT:-7233} --ui-port ${TEMPORAL_UI_PORT:-8233} --db-filename ./.namefi-astra-local-temporal-${TEMPORAL_SERVER_PORT:-7233}.db",
    "dev:temporal-server:internal": "temporal server start-dev --port ${TEMPORAL_SERVER_PORT:-7233} --ui-port ${TEMPORAL_UI_PORT:-8233} --db-filename ./.namefi-astra-local-temporal-${TEMPORAL_SERVER_PORT:-7233}.db",
    "dev:frontend": "bun run scripts/dev/run.ts --frontend-only",
    "dev:frontend:internal": "bun --cwd=apps/frontend dev:internal",
    "dev:frontend:remote": "ENVIRONMENT=development bun --cwd=apps/frontend dev:remote",
    "dev": "bun run scripts/dev/run.ts",
    "dev:base": "bun run scripts/dev/run.ts --base",
    "typecheck": "turbo typecheck",
    "test": "NODE_ENV=test turbo test",
    "test:watch": "NODE_ENV=test turbo test:watch",
    "test:coverage": "NODE_ENV=test turbo test:coverage",
    "sherif": "bunx sherif@latest",
    "sherif:fix": "bunx sherif@latest -f",
    "test:ci": "act -j test --container-architecture linux/amd64",
    "test:ci:dry": "act -j test -n",
    "sgr": "bun run scripts/run-sgr.ts scan *",
    "sgr:fix": "bun run scripts/run-sgr.ts scan --fix *",
    "validate": "concurrently -n 'typecheck,biome,sherif,sgr' -c 'blue.bold,green.bold,yellow.bold,red.bold' \"turbo typecheck --concurrency ${TURBO_TYPECHECK_CONCURRENCY:-4}\" \"turbo check:error --concurrency ${TURBO_CHECKERROR_CONCURRENCY:-4}\" \"bun sherif\" \"bun sgr\"",
    "validate:pre-push": "concurrently -n 'typecheck,biome,sherif' -c 'blue.bold,green.bold,yellow.bold' \"turbo typecheck --concurrency ${TURBO_TYPECHECK_CONCURRENCY:-1}\" \"bun check:error\" \"bun sherif\"",
    "validate:secrets": "turbo validate:secrets",
    "knip": "bunx knip"
  },
  "trustedDependencies": [
    "@ast-grep/cli",
    "@biomejs/biome",
    "@infisical/cli",
    "@reown/appkit",
    "@swc/core",
    "@tailwindcss/oxide",
    "@temporalio/core-bridge",
    "bufferutil",
    "esbuild",
    "keccak",
    "lefthook",
    "protobufjs",
    "sharp",
    "utf-8-validate"
  ]
}
