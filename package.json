{
  "name": "namefi-astra",
  "private": true,
  "workspaces": ["apps/*", "tooling/*", "packages/*"],
  "engines": {
    "node": ">=22.13.1"
  },
  "packageManager": "bun@1.2.7",
  "devDependencies": {
    "@ast-grep/cli": "^0.18.0",
    "@biomejs/biome": "1.9.4",
    "@infisical/cli": "^0.40.0",
    "@vitest/coverage-v8": "^3.1.2",
    "lefthook": "^1.11.6",
    "turbo": "^2.4.4",
    "vitest": "^3.1.2"
  },
  "scripts": {
    "preinstall": "bun run fix-infisical",
    "fix-infisical": "bun --cwd node_modules/@infisical/cli preinstall",
    "link-infisical": "bun run scripts/link-infisical.ts",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "dev:backend:api": "ENVIRONMENT=local bun --cwd=apps/backend with-env dev",
    "dev:backend:email": "ENVIRONMENT=local bun --cwd=apps/backend with-env dev:email",
    "dev:backend:temporal": "ENVIRONMENT=local bun --cwd=apps/backend with-env dev:temporal",
    "dev:temporal-server": "ENVIRONMENT=local temporal server start-dev",
    "dev:frontend": "ENVIRONMENT=local bun --cwd=apps/frontend with-env dev",
    "dev": "concurrently \"bun run dev:backend:api\" \"bun run dev:frontend\" \"bun run dev:backend:email\" \"bun run dev:temporal-server\" \"bun run dev:backend:temporal\"",
    "typecheck": "turbo typecheck",
    "test": "NODE_ENV=test turbo test",
    "test:watch": "NODE_ENV=test turbo test:watch",
    "test:coverage": "NODE_ENV=test turbo test:coverage",
    "sherif": "bunx sherif@latest",
    "sherif:fix": "bunx sherif@latest -f",
    "test:ci": "act -j test --container-architecture linux/amd64",
    "test:ci:dry": "act -j test -n",
    "sgr": "node run-sgr.js scan",
    "sgr:fix": "node run-sgr.js scan --fix",
    "validate": "turbo typecheck && bun check:error && bun sherif && bun sgr",
    "validate:secrets": "turbo validate:secrets"
  },
  "trustedDependencies": ["@biomejs/biome", "esbuild", "lefthook", "sharp"]
}
