{
  "name": "namefi-astra",
  "private": true,
  "workspaces": [
    "apps/*",
    "tooling/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.13.1"
  },
  "packageManager": "bun@1.3.12",
  "catalog": {
    "@bprogress/next": "^3.2.12",
    "@base-ui/react": "^1.1.0",
    "@c15t/nextjs": "^2.1.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "@temporalio/activity": "1.13.1",
    "@temporalio/client": "1.13.1",
    "@temporalio/common": "1.13.1",
    "@temporalio/testing": "1.13.1",
    "@temporalio/worker": "1.13.1",
    "@temporalio/workflow": "1.13.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.13.14",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript/native-preview": "^7.0.0-dev.20260202.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.7.0",
    "motion": "12.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "19.2.6",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.64.0",
    "server-only": "^0.0.1",
    "shadcn": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "viem": "2.52.0",
    "vitest": "^3.2.4",
    "wagmi": "^2.14.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.18.0",
    "@biomejs/biome": "^2.4.13",
    "@infisical/cli": "^0.43.16",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^3.1.2",
    "concurrently": "^9.1.2",
    "knip": "^5.64.2",
    "lefthook": "^1.11.6",
    "playwright": "^1.60.0",
    "turbo": "2.9.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3",
    "webpack": "5.99.9"
  },
  "overrides": {
    "@ethersproject/hash": "5.8.0",
    "@reown/appkit": "1.8.14",
    "date-fns": "4.1.0",
    "webpack": "5.99.9"
  },
  "scripts": {
    "clean:workspaces": "turbo clean",
    "clean:root": "git clean -xdf node_modules out .turbo .next && find apps packages tooling -type d -name node_modules -prune -exec rm -rf {} +",
    "clean:all": "bun run clean:workspaces && bun run clean:root",
    "prepare": "sh scripts/prepare.sh",
    "rulesync:generate": "bunx --yes rulesync@latest generate -c rulesync.jsonc --simulate-skills",
    "fix-infisical": "bun --cwd node_modules/@infisical/cli preinstall",
    "link-infisical": "bun run scripts/link-infisical.ts",
    "check": "biome check .",
    "check:error": "biome check . --diagnostic-level=error",
    "check:staged": "biome check . --staged --diagnostic-level=error --no-errors-on-unmatched --files-ignore-unknown=true",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "dev:backend:api": "bun run scripts/dev/run.ts --backend-only",
    "dev:backend:api:internal": "bun --cwd=apps/backend dev:internal",
    "dev:backend:email": "bun --cwd=apps/backend dev:email",
    "dev:backend:email:internal": "bun --cwd=apps/backend dev:email:internal",
    "dev:backend:temporal": "bun --cwd=apps/backend dev:temporal",
    "dev:backend:temporal:internal": "bun --cwd=apps/backend dev:temporal:internal",
    "dev:temporal-server": "temporal server start-dev --port ${TEMPORAL_SERVER_PORT:-7233} --ui-port ${TEMPORAL_UI_PORT:-8233} --db-filename ./.namefi-astra-local-temporal-${TEMPORAL_SERVER_PORT:-7233}.db",
    "dev:temporal-server:internal": "temporal server start-dev --port ${TEMPORAL_SERVER_PORT:-7233} --ui-port ${TEMPORAL_UI_PORT:-8233} --db-filename ./.namefi-astra-local-temporal-${TEMPORAL_SERVER_PORT:-7233}.db",
    "dev:frontend": "bun run scripts/dev/run.ts --frontend-only",
    "dev:frontend:internal": "bun --cwd=apps/frontend dev:internal",
    "dev:frontend:remote": "ENVIRONMENT=development bun --cwd=apps/frontend dev:remote",
    "dev": "bun run scripts/dev/run.ts",
    "dev:base": "bun run scripts/dev/run.ts --base",
    "typecheck": "turbo run typecheck",
    "typecheck:affected": "turbo run typecheck --affected --concurrency ${TURBO_TYPECHECK_CONCURRENCY:-2} --output-logs=errors-only",
    "test": "NODE_ENV=test turbo run test",
    "test:watch": "NODE_ENV=test turbo run test:watch",
    "test:coverage": "NODE_ENV=test turbo run test:coverage",
    "test:e2e:namefi-dev": "playwright test -c playwright.namefi-dev.config.ts",
    "lighthouse:namefi": "bun run scripts/lighthouse-namefi.ts",
    "sherif": "bunx sherif@latest",
    "sherif:fix": "bunx sherif@latest -f",
    "test:ci": "act -j test --container-architecture linux/amd64",
    "test:ci:dry": "act -j test -n",
    "sgr": "bun run scripts/run-sgr.ts scan *",
    "sgr:fix": "bun run scripts/run-sgr.ts scan --fix *",
    "validate": "concurrently -n 'typecheck,biome,sherif,sgr,i18n' -c 'blue.bold,green.bold,yellow.bold,red.bold,magenta.bold' \"turbo run typecheck --concurrency ${TURBO_TYPECHECK_CONCURRENCY:-4}\" \"turbo run check:error --concurrency ${TURBO_CHECKERROR_CONCURRENCY:-4}\" \"bun sherif\" \"bun sgr\" \"bun --cwd=apps/frontend run check:i18n\"",
    "validate:staged": "concurrently -n 'typecheck,biome,sherif' -c 'blue.bold,green.bold,yellow.bold' \"bun run typecheck:affected\" \"bun run check:staged\" \"bun sherif\"",
    "validate:pre-push": "concurrently -n 'typecheck,biome,sherif,i18n' -c 'blue.bold,green.bold,yellow.bold,magenta.bold' \"turbo run typecheck --concurrency ${TURBO_TYPECHECK_CONCURRENCY:-1}\" \"bun check:error\" \"bun sherif\" \"bun --cwd=apps/frontend run check:i18n\"",
    "validate:secrets": "turbo run validate:secrets",
    "knip": "bunx knip"
  },
  "trustedDependencies": [
    "@ast-grep/cli",
    "@biomejs/biome",
    "@infisical/cli",
    "@reown/appkit",
    "@swc/core",
    "@tailwindcss/oxide",
    "@temporalio/core-bridge",
    "bufferutil",
    "esbuild",
    "keccak",
    "lefthook",
    "protobufjs",
    "sharp",
    "utf-8-validate"
  ],
  "patchedDependencies": {
    "@ai-sdk/google@3.0.53": "patches/@ai-sdk%2Fgoogle@3.0.53.patch"
  }
}
