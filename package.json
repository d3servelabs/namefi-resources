    "apps/*",
    "tooling/*"
  ],
  "engines": {
    "node": ">=22.13.1"
  },
  "packageManager": "bun@1.2.4",
  "devDependencies": {
    "lefthook": "^1.11.2",
    "turbo": "^2.4.4"
