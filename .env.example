# Docker Compose (preview) defaults
ENVIRONMENT=preview
LOG_LEVEL=debug
TEMPORAL_API_URL=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_WORKER_PORT=3001
SMTP_HOST=smtp.mail.namefi.dev
SMTP_PORT=2025
SMTP_SECURE=false
APP_URL=localhost:3001
ALLOW_HTTP=true
ALLOW_ALL_ORIGINS=true
NAMEFI_FIRST_PARTY_HOSTNAMES=localhost,namefi.localhost,astra.localhost
ALLOWED_CHAINS=11155111

# Frontend build/runtime overrides
BACKEND_URL=http://localhost:3000
RESOURCES_URL=https://localhost:3002
FIRST_PARTY_DEPLOYMENT_URL=http://localhost:5050
GA_MEASUREMENT_ID=G-XXXXXXXXXX
PRIVY_APP_ID=your-privy-app-id
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
HUNT_CAMPAIGN_KEYS=cv-2025-07-16,cta-2025-07-16
# Optional. Master access code. When set on non-prod environments and the host
# matches `<tld>.astra.namefi.dev` or `<tld>.poweredby.namefi.dev`, the
# frontend shows an access-code gate. The master opens every TLD; per-TLD
# overrides below are accepted in addition. Leave both unset to disable the
# gate.
# FRONTEND_PREVIEW_GATE_PASSWORD=
#
# Optional. Per-TLD access codes as a JSON object. Each entry is accepted only
# on its own TLD; the master above is also always accepted. Magic-link unlock
# via GET /preview?code=<accessCode> sets the same cookies as the form.
# FRONTEND_PREVIEW_GATE_PASSCODES={"uniswap":"...","aave":"...","namefi":"..."}

# Backend secrets (required)
DATABASE_URL=postgresql://user:password@host:5432/namefi
PRIVY_APP_SECRET=your-privy-app-secret
PRIVY_WEBHOOK_SECRET=your-privy-webhook-secret
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
API_AUTH_KEY=your-api-auth-key
ALCHEMY_API_KEY=your-alchemy-api-key
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
WHOIS_API_KEY=your-whois-api-key
DYNADOT_GDG_API_KEY=your-dynadot-gdg-api-key
DYNADOT_REGULAR_API_KEY=your-dynadot-regular-api-key
DEFAULT_EPP_CODE_ENCRYPTION_KEY_ID=your-epp-encryption-key-id
LEGACY_DB_URL=postgresql://user:password@host:5432/legacy
LISTMONK_BASE_URL=https://listmonk.example.com
LISTMONK_USERNAME=listmonk_user
LISTMONK_PASSWORD=listmonk_password
BIGQUERY_PROJECT_ID=your-bigquery-project-id
BIGQUERY_KEY_FILE_PATH=/path/to/bigquery.json
BIGQUERY_AUDIT_DATASET_ID=your_audit_dataset
BIGQUERY_AUDIT_TABLE_ID=your_audit_table
VISION_API_KEY=your-vision-api-key
OPENSEA_API_KEY=your-opensea-api-key
AVAILABILITY_API_AUTH_KEY=your-availability-api-key
PUBLIC_ROUTER_AUTH_KEY=your-public-router-auth-key
COOKIE_SECRET=your-cookie-secret
ALTCHA_HMAC_KEY=your-altcha-hmac-key

# Optional secrets
# TEMPORAL_API_KEY=
# SMTP_USERNAME=
# SMTP_PASSWORD=
# GOOGLE_CLOUD_PROJECT_ID=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# NAMEFI_ALERT_SLACK_WEBHOOK_URL=
# NAMEFI_JUSTAING_ALERT_SLACK_WEBHOOK_URL=
# NAMEFI_ASSET_REPORT_SLACK_WEBHOOK_URL=
# Slack incoming webhook for the Security Scan workflow (CI alert channel).
# Set as a GitHub Actions secret of the same name (directly or via Infisical sync);
# the workflow falls back to SLACK_WEBHOOK_RELEASE_CHANNEL_URL when unset.
# SLACK_WEBHOOK_SECURITY_CHANNEL_URL=
# INFISICAL_SERVICE_TOKEN=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=
# INFISICAL_SECRETS_PATH=/
